# WearSync Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=4000
NODE_ENV=development
JWT_SECRET=change_this_to_a_random_secret_string

# Database (SQLite - local file)
DB_PATH=./data/wearsync.db

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ─────────────────────────────────────────
# GARMIN
# https://developer.garmin.com/health-api/
# ─────────────────────────────────────────
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=
GARMIN_CALLBACK_URL=http://localhost:4000/auth/garmin/callback

# ─────────────────────────────────────────
# FITBIT
# https://dev.fitbit.com/apps/new
# ─────────────────────────────────────────
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
FITBIT_CALLBACK_URL=http://localhost:4000/auth/fitbit/callback

# ─────────────────────────────────────────
# WHOOP
# https://developer.whoop.com/
# ─────────────────────────────────────────
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_CALLBACK_URL=http://localhost:4000/auth/whoop/callback

# ─────────────────────────────────────────
# WITHINGS
# https://developer.withings.com/
# ─────────────────────────────────────────
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=
WITHINGS_CALLBACK_URL=http://localhost:4000/auth/withings/callback

# ─────────────────────────────────────────
# AMAZFIT / ZEPP
# https://developer.zepp.com/
# ─────────────────────────────────────────
ZEPP_CLIENT_ID=
ZEPP_CLIENT_SECRET=
ZEPP_CALLBACK_URL=http://localhost:4000/auth/zepp/callback

# ─────────────────────────────────────────
# OURA RING
# https://cloud.ouraring.com/personal-access-tokens (PAT, easiest)
# or https://cloud.ouraring.com/docs/authentication (OAuth)
# ─────────────────────────────────────────
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
OURA_CALLBACK_URL=http://localhost:4000/auth/oura/callback
# Personal Access Token (simpler — paste here to skip OAuth):
OURA_PAT=

# ─────────────────────────────────────────
# APPLE HEALTH
# No API key needed — export from iPhone:
# Settings → Health → your name → Export All Health Data
# Then upload export.xml via the frontend
# ─────────────────────────────────────────
